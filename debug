import sys
import time
sys.path.insert(0, 'build/python')

import guideusb2 as g
import numpy as np
from tfan import ThermalLandmarks

linear_cal  = g.CameraLinearCal()
last_status = [None]
last_frame  = [None]

def on_frame(frame):
    last_frame[0] = frame
    if last_status[0] is not None:
        try:
            linear_cal.fit(frame.y16, last_status[0])
        except:
            pass

print("Loading T-FAKE...")
landmarker = ThermalLandmarks(device="cpu", n_landmarks=478)
print("Ready.")

cam = g.Camera(g.DeviceInfo(serial_port="/dev/ttyACM0"))
cam.configure_thermography(g.ThermographyConfig(emissivity=98))
cam.start(on_frame)
print("Warming up... 5 seconds")
time.sleep(5)

print("Waiting for calibration...")
for attempt in range(20):
    try:
        s = cam.serial().query_temp_status(retries=2, wait_seconds=1.5)
        if s:
            last_status[0] = s
            if last_frame[0] is not None:
                linear_cal.fit(last_frame[0].y16, s)
            print(f"Calibration ready — "
                  f"min:{s.min_c:.1f} max:{s.max_c:.1f}")
            break
    except Exception as e:
        print(f"Attempt {attempt+1} failed: {e}")
    time.sleep(1)

if not linear_cal.ready():
    print("Calibration failed — exiting")
    cam.stop()
    sys.exit(1)

print("Running — point sensor at face, Ctrl+C to stop")
print("-" * 60)

try:
    while True:
        try:
            s = cam.serial().query_temp_status(retries=1, wait_seconds=1.0)
            if s:
                last_status[0] = s
                linear_cal.fit(last_frame[0].y16, s)
        except:
            pass

        if last_frame[0] is None:
            time.sleep(1)
            continue

        temps  = linear_cal.decode(last_frame[0].y16)
        h, w   = temps.shape

        t_min  = float(temps.min())
        t_max  = float(temps.max())
        spread = t_max - t_min

        # Clip to body temp range — makes face bright
        clip_min = 28.0
        clip_max = 38.0
        temps_clipped = np.clip(temps, clip_min, clip_max)
        gray = ((temps_clipped - clip_min) /
                (clip_max - clip_min) * 255).astype(np.uint8)

        # Run T-FAKE
        try:
            landmarks, confidences = landmarker.process(gray)
        except Exception as e:
            print(f"Error: {e}")
            time.sleep(2)
            continue

        if landmarks is not None:
            # landmarks is a list of detections
            # each detection is an array of shape (478, 2)
            print(f"Type: {type(landmarks)}")
            print(f"Len: {len(landmarks)}")

            if isinstance(landmarks, list):
                # Multiple faces possible — take first one
                if len(landmarks) > 0:
                    lms = np.array(landmarks[0], dtype=np.float32)
                    confs = np.array(confidences[0], dtype=np.float32).flatten() \
                            if isinstance(confidences, list) else \
                            np.array(confidences, dtype=np.float32).flatten()
                else:
                    print("Empty landmarks list")
                    time.sleep(2)
                    continue
            else:
                lms   = np.array(landmarks,   dtype=np.float32)
                confs = np.array(confidences, dtype=np.float32).flatten()

            print(f"lms shape: {lms.shape}")
            print(f"lms max x: {lms[:, 0].max():.1f}  "
                  f"max y: {lms[:, 1].max():.1f}")
            print(f"Frame size: {w}x{h}")

            # Figure out the scale factor
            # T-FAKE processes at 224x224 internally
            # Landmarks are in that space — scale back to our frame
            internal_w = lms[:, 0].max()
            internal_h = lms[:, 1].max()
            scale_x = w / internal_w if internal_w > 0 else 1.0
            scale_y = h / internal_h if internal_h > 0 else 1.0

            print(f"Scale factors: x={scale_x:.3f} y={scale_y:.3f}")

            # Scale landmarks to our frame
            lms_scaled = lms.copy()
            lms_scaled[:, 0] *= scale_x
            lms_scaled[:, 1] *= scale_y

            # Read temperature at key landmarks
            for idx, name in [(133, "L-canthus"),
                              (362, "R-canthus"),
                              (10,  "Forehead"),
                              (1,   "Nose tip")]:
                if idx < len(lms_scaled):
                    px = int(lms_scaled[idx, 0])
                    py = int(lms_scaled[idx, 1])
                    if 0 <= px < w and 0 <= py < h:
                        # Average 3x3 region
                        r = 3
                        region = temps[
                            max(0, py-r):min(h, py+r),
                            max(0, px-r):min(w, px+r)]
                        t = float(np.max(region))
                        print(f"  {name}: "
                              f"pixel({px},{py}) "
                              f"temp:{t:.1f}C")
                    else:
                        print(f"  {name}: out of bounds "
                              f"({px},{py})")

            spread_str = f"spread:{spread:.1f}C"
            print(f"{spread_str}  landmarks:{len(lms)}")

        else:
            print(f"spread:{spread:.1f}C  NO DETECTION")

        print("-" * 40)
        time.sleep(2)

except KeyboardInterrupt:
    print("\nStopped.")
finally:
    cam.stop()
    print("Done.")

